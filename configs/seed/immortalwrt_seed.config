# ImmortalWrt Seed 模板 — 所有 ImmortalWrt 设备的公共基础包
# 用法: cat configs/seed/immortalwrt_seed.config >> .config && make defconfig
# 注意: 此文件仅包含 CONFIG_PACKAGE_* 等通用包选项
#       架构和硬件相关配置请保留在各设备 .config 中

# --- 基础 LuCI 界面 ---
CONFIG_PACKAGE_luci=y

# --- 常用工具 ---
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget=y
CONFIG_PACKAGE_openssl-util=y
CONFIG_PACKAGE_coreutils=y
CONFIG_PACKAGE_tar=y
CONFIG_PACKAGE_xz=y

# --- SSH 服务 ---
CONFIG_PACKAGE_openssh-server=y
CONFIG_PACKAGE_openssh-sftp-server=y

# --- OTA 固件更新 ---
CONFIG_PACKAGE_luci-app-ghfu=y
CONFIG_PACKAGE_luci-i18n-ghfu-zh-cn=y
